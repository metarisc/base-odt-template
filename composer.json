{
    "name": "metarisc-odt/base-odt-template",
    
    "description": "ODT rendering",

    "keywords": ["odt", "php"],

    "license": "CECILL-2.1",

    "require": {
        "php": "^8.2",
        "adbario/php-dot-notation": "^2.0",
        "intervention/image": "^2.0",
        "bacon/bacon-qr-code": "^2.0",
        "nelexa/zip": "^4.0",
        "league/commonmark": "^2.7"
    },

    "require-dev": {
        "kdubuc/php-cs-fixer-rules": "^1.0",
        "phpunit/phpunit": "^9.0"
    },

    "autoload": {
        "psr-4": {
            "Kdubuc\\Odt\\": "src"
        }
    },

    "scripts": {
        "code:tests": "vendor/bin/phpunit",
        "code:fix-cs": "vendor/bin/php-cs-fixer fix --config=vendor/kdubuc/php-cs-fixer-rules/php-cs-fixer.php"
    },

    "prefer-stable": true,
    "minimum-stability": "dev"
}
